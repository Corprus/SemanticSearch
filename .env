# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME=Semantic Search Service
API_VERSION=0.1
DEBUG=true
JWT_SECRET_KEY=abcderghijklmnopqrstuvwxyz01234567890
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=30

# Postgres
POSTGRES_DB=semantic_search_db
POSTGRES_USER=db_user
POSTGRES_PASSWORD=db_pass
POSTGRES_HOST=database
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=rabbit_user
RABBITMQ_PASSWORD=rabbit_user
RABBITMQ_VHOST=/

#Worker
WORKER_CONCURRENCY=2
HF_HUB_DISABLE_PROGRESS_BARS=1
TQDM_DISABLE=1
TASK_PROCESS_SEARCH_QUERY_NAME="tasks.process_search_query"
TASK_EMBED_DOCUMENT_NAME="tasks.embed_document"

#UI
UI_PORT=8051
API_BASE_URL="http://web-proxy/api"